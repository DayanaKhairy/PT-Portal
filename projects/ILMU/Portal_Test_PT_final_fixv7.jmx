              <hashTree>
                <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Display QUIZ Answer" enabled="true">
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="script">String user = vars.get(&apos;email&apos;) ?: &apos;UNKNOWN&apos;
String threadName = ctx.getThread().getThreadName()
String itemId = vars.get(&apos;QUIZ_ITEM_ID&apos;) ?: &apos;&apos;
String attemptId = vars.get(&apos;QUIZ_ATTEMPT_ID&apos;) ?: &apos;&apos;
String q = (vars.get(&apos;QUIZ_QUESTION_TEXT&apos;) ?: &apos;&apos;).replaceAll(/[\\r\\n\\t]+/, &apos; &apos;).trim()
String optId = vars.get(&apos;QUIZ_SELECTED_OPTION_ID&apos;) ?: &apos;&apos;
String opt = (vars.get(&apos;QUIZ_OPTION_TEXT&apos;) ?: &apos;&apos;).replaceAll(/[\\r\\n\\t]+/, &apos; &apos;).trim()

String qShort = q ? (q.length() &gt; 160 ? q.substring(0, 160) + &apos;...&apos; : q) : &apos;&apos;
String optShort = opt ? (opt.length() &gt; 120 ? opt.substring(0, 120) + &apos;...&apos; : opt) : &apos;&apos;

String msg = &apos;QUIZ_ANSWER | thread=&apos; + threadName +
        &apos; | user=&apos; + user +
        (attemptId ? (&apos; | attempt=&apos; + attemptId) : &apos;&apos;) +
        (itemId ? (&apos; | item=&apos; + itemId) : &apos;&apos;) +
        (qShort ? (&apos; | question=&apos; + qShort) : &apos;&apos;) +
        (optId ? (&apos; | option_id=&apos; + optId) : &apos;&apos;) +
        (optShort ? (&apos; | option=&apos; + optShort) : &apos;&apos;)

SampleResult.setSuccessful(true)
SampleResult.setResponseCodeOK()
SampleResult.setResponseMessage(&apos;Displayed quiz answer&apos;)
SampleResult.setResponseData(msg.getBytes(&apos;UTF-8&apos;))
log.info(msg)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
                </JSR223Sampler>
