  &quot;selectedOptionIds&quot;: [&#xd;
    &quot;${QUIZ_SELECTED_OPTION_ID}&quot;&#xd;
  ]&#xd;
}</stringProp>
                      <stringProp name="Argument.metadata">=</stringProp>
                    </elementProp>
                  </collectionProp>
                </elementProp>
