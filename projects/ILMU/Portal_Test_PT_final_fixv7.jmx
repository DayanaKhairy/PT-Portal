            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log Learning Assessment (GET questions)" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def user = vars.get(&apos;email&apos;) ?: &apos;UNKNOWN&apos;
def uqStart = vars.get(&apos;userQuestionnaireStartId&apos;) ?: &apos;&apos;
def uqId = vars.get(&apos;userQuestionnaireId&apos;) ?: &apos;&apos;
def threadName = ctx.getThread().getThreadName()

def flat = { String s -&gt; (s ?: &apos;&apos;).replaceAll(/[\\r\\n\\t]+/, &apos; &apos;).trim() }
def trunc = { String s, int n -&gt; s != null &amp;&amp; s.length() &gt; n ? (s.substring(0, n) + &apos;...&apos;) : (s ?: &apos;&apos;) }

def req = flat(prev.getSamplerData())
def resp = flat(prev.getResponseDataAsString())

log.info(&apos;LEARNING_ASSESSMENT_QUESTIONS | thread=&apos; + threadName +
        &apos; | user=&apos; + user +
        (uqStart ? (&apos; | userQuestionnaireStartId=&apos; + uqStart) : &apos;&apos;) +
        (uqId ? (&apos; | userQuestionnaireId=&apos; + uqId) : &apos;&apos;))</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
