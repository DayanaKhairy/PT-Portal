            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert ACCESS_TOKEN extracted" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def token = vars.get(&apos;ACCESS_TOKEN&apos;)
if (!token || token == &apos;NO_TOKEN&apos;) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&apos;ACCESS_TOKEN not extracted from login response&apos;)
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Assertion>
