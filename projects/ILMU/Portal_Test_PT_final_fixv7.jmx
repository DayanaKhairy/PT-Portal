                <stringProp name="script">def id = vars.get(&apos;QUIZ_ATTEMPT_ID&apos;)
if (!id) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&apos;QUIZ_ATTEMPT_ID not extracted from start attempt response&apos;)
}</stringProp>
