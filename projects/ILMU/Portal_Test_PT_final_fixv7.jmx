            <stringProp name="parameters"></stringProp>
            <stringProp name="script">int sent = (vars.get(&apos;AI_BM_SENT_COUNT&apos;) ?: &apos;0&apos;) as int
String user = vars.get(&apos;email&apos;) ?: &apos;UNKNOWN&apos;
String threadName = ctx.getThread().getThreadName()

if (sent != 5) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;Expected 5 BM questions sent but got &apos; + sent)
    SampleResult.setResponseData((&apos;AI_TUTOR_BM_VERIFY_FAIL | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent).getBytes(&apos;UTF-8&apos;))
    log.error(&apos;AI_TUTOR_BM_VERIFY_FAIL | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent)
} else {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseCodeOK()
    SampleResult.setResponseMessage(&apos;Verified 5 BM questions sent&apos;)
    SampleResult.setResponseData((&apos;AI_TUTOR_BM_VERIFY_PASS | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent).getBytes(&apos;UTF-8&apos;))
    log.info(&apos;AI_TUTOR_BM_VERIFY_PASS | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent)
}</stringProp>
