                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract QUIZ_SELECTED_OPTION_ID" enabled="true">
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="script">import groovy.json.JsonSlurper

def body = prev.getResponseDataAsString()
def optionId = &apos;A&apos;
def questionText = &apos;&apos;
def optionText = &apos;&apos;
if (body) {
    def json = new JsonSlurper().parseText(body)
    def data = json?.data
    def opts = (data?.options instanceof List) ? data.options : []
    if (opts &amp;&amp; opts.size() &gt; 0) {
        def first = opts[0]
        optionId = (first?.id != null) ? first.id.toString() : &apos;A&apos;
        optionText = (first?.text ?: first?.label ?: first?.title ?: first?.name ?: &apos;&apos;).toString()
    }
    questionText = (data?.question ?: data?.questionText ?: data?.text ?: data?.title ?: data?.prompt ?: &apos;&apos;).toString()
}
vars.put(&apos;QUIZ_SELECTED_OPTION_ID&apos;, optionId)
vars.put(&apos;QUIZ_QUESTION_TEXT&apos;, questionText)
vars.put(&apos;QUIZ_OPTION_TEXT&apos;, optionText)</stringProp>
