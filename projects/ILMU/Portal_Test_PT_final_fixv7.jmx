          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Verify 5 Sejarah Questions Sent" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">int sent = (vars.get(&apos;AI_SEJARAH_SENT_COUNT&apos;) ?: &apos;0&apos;) as int
String user = vars.get(&apos;email&apos;) ?: &apos;UNKNOWN&apos;
String threadName = ctx.getThread().getThreadName()

if (sent != 5) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&apos;500&apos;)
    SampleResult.setResponseMessage(&apos;Expected 5 Sejarah questions sent but got &apos; + sent)
    SampleResult.setResponseData((&apos;AI_TUTOR_SEJARAH_VERIFY_FAIL | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent).getBytes(&apos;UTF-8&apos;))
    log.error(&apos;AI_TUTOR_SEJARAH_VERIFY_FAIL | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent)
} else {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseCodeOK()
    SampleResult.setResponseMessage(&apos;Verified 5 Sejarah questions sent&apos;)
    SampleResult.setResponseData((&apos;AI_TUTOR_SEJARAH_VERIFY_PASS | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent).getBytes(&apos;UTF-8&apos;))
    log.info(&apos;AI_TUTOR_SEJARAH_VERIFY_PASS | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | sent=&apos; + sent)
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
