            </LoopController>
            <hashTree>
              <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="WS Read AI Tutor Chunk" enabled="true">
                <boolProp name="createNewConnection">false</boolProp>
                <stringProp name="TestPlan.comments">Read streaming delta or done frame</stringProp>
                <stringProp name="server"></stringProp>
