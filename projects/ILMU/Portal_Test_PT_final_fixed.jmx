            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Log AI Question Sent" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">int current = (vars.get(&apos;AI_SENT_COUNT&apos;) ?: &apos;0&apos;) as int
current++
vars.put(&apos;AI_SENT_COUNT&apos;, String.valueOf(current))

String user = vars.get(&apos;email&apos;) ?: &apos;UNKNOWN&apos;
String qno = vars.get(&apos;question_no&apos;) ?: String.valueOf(current)
String q = vars.get(&apos;question&apos;) ?: &apos;&apos;
String threadName = ctx.getThread().getThreadName()

log.info(&apos;AI_TUTOR_SENT | thread=&apos; + threadName + &apos; | user=&apos; + user + &apos; | question_no=&apos; + qno + &apos; | question=&apos; + q)</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Sampler>
